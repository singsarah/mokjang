# 이 파일은 실제 값 없이 커밋됩니다. 실제 값은 .env.local 에 채우세요.
# .env.local 은 .gitignore 로 절대 커밋되지 않습니다.

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # 서버 전용, 절대 클라이언트 노출 금지

# === 구글 OAuth (Supabase Auth 대시보드에 등록) ===
# 클라이언트에는 필요 없음. Supabase가 대신 처리.
# 이 값들은 .env 에 두지 말고 Supabase 대시보드에만.

# === 이메일 발송 (SendGrid) ===
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com

# === Web Push (VAPID) ===
# npx web-push generate-vapid-keys 로 생성
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# === OCR (선택) ===
# 일정표 PDF/이미지 자동 추출용
GOOGLE_CLOUD_VISION_API_KEY=

# === 기타 ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
